<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>com.opensurge.helper</string>
  <key>ProgramArguments</key><array>
    <string>/Library/PrivilegedHelperTools/com.opensurge.helper</string>
    <string>--allowed-config-root</string><string>/Library/Application Support/OpenSurge</string>
    <string>--socket-group</string><string>admin</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>UserName</key><string>root</string>
  <key>StandardOutPath</key><string>/Library/Logs/OpenSurge/helper.log</string>
  <key>StandardErrorPath</key><string>/Library/Logs/OpenSurge/helper-error.log</string>
</dict></plist>
